{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "skipLibCheck": true,
    "types": ["node"],
    "lib": ["ES2024", "DOM"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts"],
  "comment": "*.test.ts run via `bun test` (built-in bun:test, no dep); excluded from tsc since bun-types is not an allowed devDep.",
  "exclude": ["**/*.test.ts"]
}
